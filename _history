bles><block type=\"device_forever\" x=\"32\" y=\"48\"><statement name=\"HANDLER\"><block type=\"device_set_digital_pin\"><value name=\"name\"><shadow type=\"digital_pin_shadow\"><field name=\"pin\">DigitalPin.P0</field></shadow></value><value name=\"value\"><shadow type=\"math_number_minmax\"><mutation min=\"0\" max=\"1\" label=\"Value\" precision=\"0\"></mutation><field name=\"SLIDER\">1</field></shadow></value><next><block type=\"device_show_number\"><value name=\"number\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"device_get_digital_pin\"><value name=\"name\"><shadow type=\"digital_pin_shadow\"><field name=\"pin\">DigitalPin.P15</field></shadow></value></block></value></block></next></block></statement></block></xml>","main.ts":"","README.md":"","pxt.json":"{\n    \"name\": \"unihiker test 27/03\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"Carte-d-extension-DFR1216\": \"github:alexandre-a4/Carte-d-extension-DFR1216#d9e64fa2ac611cc7b8dd3c1059655ce26b0b6ca9\",\n        \"convoyeur-a4\": \"github:emsrn/blocs_convoyeur_a4#a9a3844c088a8503d7aa24251d590b23b7d02339\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\"\n    ],\n    \"targetVersions\": {\n        \"branch\": \"stable8.0\",\n        \"tag\": \"v8.0.18\",\n        \"commits\": \"https://github.com/microsoft/pxt-microbit/commits/ec67ee1ad9a7c41ee95376e7577127b32d4d233a\",\n        \"target\": \"8.0.18\",\n        \"pxt\": \"12.0.16\"\n    },\n    \"preferredEditor\": \"blocksprj\"\n}\n"}},{"timestamp":1776419062167,"editorVersion":"8.0.21","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"pxt-on-start\" x=\"0\" y=\"0\"></block></xml>","main.ts":"\n","README.md":"","custom.ts":"namespace a4_Portail{\n    \n    //% color=#2E8B57\n    enum MotorDirection {\n        //% block=\"ouvrir\"\n        CW = 0,\n        //% block=\"fermer\"\n        CCW = 1\n    }\n\n    enum MotorID {\n        //% block=\"motor 1\"\n        M1 = 0,\n        //% block=\"motor 2\"\n        M2,\n        //% block=\"motor 3\"\n        M3,\n        //% block=\"motor 4\"\n        M4\n    }\n\n    const I2C_ADDR = 0x33\n\n    let initialized = false\n    let lastDirection = [0, 0, 0, 0]\n    let globalBrightness = 255\n\n    function init() {\n        if (!initialized) {\n            initialized = true\n            basic.pause(100)\n        }\n    }\n\n    function writeReg(reg: number, data: Buffer) {\n        let buf = pins.createBuffer(data.length + 1)\n        buf[0] = reg\n        for (let i = 0; i < data.length; i++) {\n            buf[i + 1] = data[i]\n        }\n        pins.i2cWriteBuffer(I2C_ADDR, buf)\n    }\n\n    function readReg(reg: number, len: number): Buffer {\n        pins.i2cWriteNumber(I2C_ADDR, reg, NumberFormat.UInt8BE)\n        return pins.i2cReadBuffer(I2C_ADDR, len)\n    }\n\n    //% block=\"%dir portail speed %speed \\\\%\"\n    //% speed.min=0 speed.max=100\n    //% group=\"Motors\"\n    export function motorRun(dir: MotorDirection, speed: number) {\n\n        init()\n\n        speed = Math.clamp(0, 100, speed)\n        let duty = Math.map(speed, 0, 100, 0, 4095)\n        let m = MotorID.M4\n\n        let base = 0x04 + m * 4\n\n        // stop avant inversion\n        if (lastDirection[m] != dir) {\n            writeReg(base, pins.createBuffer(2))\n            writeReg(base + 2, pins.createBuffer(2))\n            basic.pause(50)\n        }\n\n        let buf = pins.createBuffer(2)\n        buf[0] = (duty >> 8) & 0xFF\n        buf[1] = duty & 0xFF\n\n        if (dir == MotorDirection.CW) {\n            writeReg(base, buf)\n            writeReg(base + 2, pins.createBuffer(2))\n        } else {\n            writeReg(base + 2, buf)\n            writeReg(base, pins.createBuffer(2))\n        }\n\n        lastDirection[m] = dir\n    }\n}\n\n","pxt.json":"{\n    \"name\": \"unihiker test 27/03\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"custom.ts\"\n    ],\n    \"targetVersions\": {\n        \"branch\": \"stable8.0\",\n        \"tag\": \"v8.0.18\",\n        \"commits\": \"https://github.com/microsoft/pxt-microbit/commits/ec67ee1ad9a7c41ee95376e7577127b32d4d233a\",\n        \"target\": \"8.0.18\",\n        \"pxt\": \"12.0.16\"\n    },\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1776694374032,"editorVersion":"8.0.21","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"device_forever\" x=\"0\" y=\"0\"><statement name=\"HANDLER\"><block type=\"a4_Portail_portail\"><field name=\"action\">Portail.CW</field><next><block type=\"device_pause\"><value name=\"pause\"><shadow type=\"timePicker\"><field name=\"ms\">2000</field></shadow></value><next><block type=\"a4_Portail_portail\"><field name=\"action\">Portail.Stop</field></block></next></block></next></block></statement></block><block type=\"device_forever\" x=\"317\" y=\"40\"><statement name=\"HANDLER\"><block type=\"a4_Portail_led\"><field name=\"state\">LED.ON</field><next><block type=\"device_pause\"><value name=\"pause\"><shadow type=\"timePicker\"><field name=\"ms\">2000</field></shadow></value><next><block type=\"a4_Portail_led\"><field name=\"state\">LED.OFF</field><next><block type=\"device_pause\"><value name=\"pause\"><shadow type=\"timePicker\"><field name=\"ms\">2000</field></shadow></value></block></next></block></next></block></next></block></statement></block></xml>","main.ts":"\n","README.md":"","custom.ts":"//% weight=100 color=#6473E3 icon=\"\\uf085\"\nnamespace a4_Portail {\n\n    const I2C_ADDR = 0x33\n\n    let initialized = false\n    let lastDirection = [0, 0, 0, 0]\n    let globalBrightness = 255\n\n    function init() {\n        if (!initialized) {\n            initialized = true\n            basic.pause(100)\n        }\n    }\n\n    function writeReg(reg: number, data: Buffer) {\n        let buf = pins.createBuffer(data.length + 1)\n        buf[0] = reg\n        for (let i = 0; i < data.length; i++) {\n            buf[i + 1] = data[i]\n        }\n        pins.i2cWriteBuffer(I2C_ADDR, buf)\n    }\n\n    function readReg(reg: number, len: number): Buffer {\n        pins.i2cWriteNumber(I2C_ADDR, reg, NumberFormat.UInt8BE)\n        return pins.i2cReadBuffer(I2C_ADDR, len)\n    }\n\n    // =========================\n    // GPIO (AUTO CONFIG)\n    // =========================\n\n    function setAnalogInput(io: IO) {\n        writeReg(0x2c + io, pins.createBufferFromArray([2]))\n    }\n\n    //% block=\"%action portail\"\n    export function portail(action: Portail){\n        if (action == Portail.CW){\n            digitalWrite(IO.C0, GPIOState.High)\n            digitalWrite(IO.C5, GPIOState.Low)\n        }\n        if (action == Portail.CCW){\n            digitalWrite(IO.C0, GPIOState.Low)\n            digitalWrite(IO.C5, GPIOState.High)\n        }\n        if (action == Portail.Stop){\n            digitalWrite(IO.C0, GPIOState.Low)\n            digitalWrite(IO.C5, GPIOState.Low)\n        }\n    }\n\n    //% block=\"%state signal lumineux\"\n    export function led(state: Etat) {\n        if (state == Etat.ON) {\n            pins.digitalWritePin(DigitalPin.P1, 1)  \n        }\n        else if (state == Etat.OFF) {\n            pins.digitalWritePin(DigitalPin.P1, 0)\n        }\n    }\n\n    //% block=\"%state émetteur IR\"\n    export function emetteurIR(state: Etat){\n        if (state == Etat.ON) {\n            digitalWrite(IO.C1, GPIOState.Low)\n        }\n    }\n\n\n    function digitalWrite(io: IO, state: GPIOState) {\n        init()\n        setDigitalOutput(io)\n        writeReg(0x39 + io, pins.createBufferFromArray([state]))\n    }\n\n    function setDigitalOutput(io: IO) {\n        writeReg(0x2c + io, pins.createBufferFromArray([4]))\n    }\n\n    function setDigitalInput(io: IO) {\n        writeReg(0x2c + io, pins.createBufferFromArray([5]))\n    }\n\n}\n\n","enums.ts":"//% color=#2E8B57\nenum MotorID {\n    //% block=\"motor 1\"\n    M1 = 0,\n    //% block=\"motor 2\"\n    M2,\n    //% block=\"motor 3\"\n    M3,\n    //% block=\"motor 4\"\n    M4\n}\n\n//% color=#2E8B57\nenum Portail {\n    //% block=\"Ouvrir\"\n    CW = 0,\n    //% block=\"Fermer\"\n    CCW = 1,\n    //% block=\"Arrêter\"\n    Stop,\n}\n\nenum Etat {\n    //% block=\"Activer\"\n    ON, \n    //% block=\"Désactiver\"\n    OFF,\n}\n\n//% color=#1E90FF\nenum Servo {\n    S0 = 0,\n    S1,\n    S2,\n    S3,\n    S4,\n    S5\n}\n\n//% color=#FF8C00\nenum IO {\n    C0 = 0,\n    C1,\n    C2,\n    C3,\n    C4,\n    C5\n}\n\n//% color=#FF8C00\nenum GPIOState {\n    //% block=\"LOW\"\n    Low = 0,\n    //% block=\"HIGH\"\n    High = 1\n}\n\n//% color=#FF1493\nenum RGBIndex {\n    //% block=\"RGB0\"\n    RGB0 = 0,\n    //% block=\"RGB1\"\n    RGB1 = 1,\n    //% block=\"both\"\n    Both = 2\n}\n\n//% color=#FF1493\nenum RGBColor {\n    //% block=\"red\"\n    Red,\n    //% block=\"green\"\n    Green,\n    //% block=\"blue\"\n    Blue,\n    //% block=\"yellow\"\n    Yellow,\n    //% block=\"cyan\"\n    Cyan,\n    //% block=\"magenta\"\n    Magenta,\n    //% block=\"white\"\n    White,\n    //% block=\"off\"\n    Off\n}","pxt.json":"{\n    \"name\": \"unihiker test 17/04\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"custom.ts\",\n        \"enums.ts\"\n    ],\n    \"targetVersions\": {\n        \"branch\": \"stable8.0\",\n        \"tag\": \"v8.0.18\",\n        \"commits\": \"https://github.com/microsoft/pxt-microbit/commits/ec67ee1ad9a7c41ee95376e7577127b32d4d233a\",\n        \"target\": \"8.0.18\",\n        \"pxt\": \"12.0.16\"\n    },\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1776781275121,"editorVersion":"8.0.21","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"pxt-on-start\" x=\"0\" y=\"0\"></block><block type=\"device_forever\" x=\"209\" y=\"24\"></block></xml>","main.ts":"basic.forever(function () {\n\t\n})\n","README.md":"","custom.ts":"//% weight=100 color=#6473E3 icon=\"\\uf085\"\nnamespace a4_Portail {\n\n    const I2C_ADDR = 0x33\n\n    let initialized = false\n    let lastDirection = [0, 0, 0, 0]\n    let globalBrightness = 255\n\n    function init() {\n        if (!initialized) {\n            initialized = true\n            basic.pause(100)\n        }\n    }\n\n    function writeReg(reg: number, data: Buffer) {\n        let buf = pins.createBuffer(data.length + 1)\n        buf[0] = reg\n        for (let i = 0; i < data.length; i++) {\n            buf[i + 1] = data[i]\n        }\n        pins.i2cWriteBuffer(I2C_ADDR, buf)\n    }\n\n    function readReg(reg: number, len: number): Buffer {\n        pins.i2cWriteNumber(I2C_ADDR, reg, NumberFormat.UInt8BE)\n        return pins.i2cReadBuffer(I2C_ADDR, len)\n    }\n\n    // =========================\n    // GPIO (AUTO CONFIG)\n    // =========================\n\n    function setAnalogInput(io: IO) {\n        writeReg(0x2c + io, pins.createBufferFromArray([2]))\n    }\n\n    //% block=\"%action portail sur C2 et C1\"\n    export function portail(action: Portail){\n        if (action == Portail.CW){\n            digitalWrite(IO.C2, GPIOState.High)\n            digitalWrite(IO.C1, GPIOState.Low)\n        }\n        if (action == Portail.CCW){\n            digitalWrite(IO.C2, GPIOState.Low)\n            digitalWrite(IO.C1, GPIOState.High)\n        }\n        if (action == Portail.Stop){\n            digitalWrite(IO.C2, GPIOState.Low)\n            digitalWrite(IO.C1, GPIOState.Low)\n        }\n    }\n\n    //% block=\"%state signal lumineux\"\n    export function led(state: Etat) {\n        if (state == Etat.ON) {\n            pins.digitalWritePin(DigitalPin.P0, 1)  \n        }\n        else if (state == Etat.OFF) {\n            pins.digitalWritePin(DigitalPin.P0, 0)\n        }\n    }\n\n    //% block=\"%state émetteur IR sur C1\"\n    export function emetteurIR(state: Etat){\n        if (state == Etat.ON) {\n            digitalWrite(IO.C1, GPIOState.Low)\n        }\n    }\n\n    //%block=\"Bouton-poussoir %loc appuyé\"\n    export function buttonStateBoolean(loc: ButtonLocation){\n        let pin = (loc == ButtonLocation.Ext) ? DigitalPin.P1 : DigitalPin.P2 //affecte à une cte le pin correspondant au BP sélectionné par l'utilisateur\n        return pins.digitalReadPin(pin)==1 //renvoie Vrai si le BP est appuyé \n    }\n\n    //%block=\"%module\" \n    export function moduleState(module: Modules){\n        switch (module){\n            case Modules.BPExt: return pins.digitalReadPin(DigitalPin.P1)\n            case Modules.BPInt: return pins.digitalReadPin(DigitalPin.P2)\n            case Modules.LED: return pins.digitalReadPin(DigitalPin.P0)\n            case Modules.LimSwitchO: return pins.digitalReadPin(DigitalPin.P15)\n            case Modules.LimSwitchC: return pins.digitalReadPin(DigitalPin.P14)\n            case Modules.A1Motor: return setDigitalOutput(IO.C1)                //////////////A REVOIR / A VERIFIER \n            case Modules.A2Motor: return setDigitalOutput(IO.C2)\n            case Modules.IRreceptor: return setDigitalOutput(IO.C5)             //////////////A REVOIR / A VERIFIER \n            default: return 0\n        }\n\n    }\n\n    //%block=\"Capteur de fin de course %fc activé\" \n    export function sensorState(fc: LimitSwitch){\n        let pin = (fc == LimitSwitch.Open) ? DigitalPin.P15 : DigitalPin.P14 //affecte à une cte le pin correspondant au BP sélectionné par l'utilisateur\n        return pins.digitalReadPin(pin) == 1 //renvoie Vrai si le BP est appuyé \n    }\n\n\n    function digitalWrite(io: IO, state: GPIOState) { //fonction écrire sur un pin C (0 ou 1)\n        init()\n        setDigitalOutput(io)\n        writeReg(0x39 + io, pins.createBufferFromArray([state]))\n    }\n\n    function setDigitalOutput(io: IO) {\n        writeReg(0x2c + io, pins.createBufferFromArray([4]))\n    }\n\n    function setDigitalInput(io: IO) {\n        writeReg(0x2c + io, pins.createBufferFromArray([5]))\n    }\n\n}\n\n","enums.ts":"//% color=#2E8B57\nenum MotorID {\n    //% block=\"motor 1\"\n    M1 = 0,\n    //% block=\"motor 2\"\n    M2,\n    //% block=\"motor 3\"\n    M3,\n    //% block=\"motor 4\"\n    M4\n}\n\n//% color=#2E8B57\nenum Portail {\n    //% block=\"Ouvrir\"\n    CW = 0,\n    //% block=\"Fermer\"\n    CCW = 1,\n    //% block=\"Arrêter\"\n    Stop,\n}\n\nenum Etat {\n    //% block=\"Activer\"\n    ON, \n    //% block=\"Désactiver\"\n    OFF,\n}\n\nenum ButtonLocation{\n    //% block=\"Extérieur\"\n    Ext,\n    //% block=\"Intérieur\"\n    Int,\n}\n\nenum Modules{\n    //%block=\"Capteur de fin de course ouverture\"\n    LimSwitchO,\n    //%block=\"Capteur de fin de course fermeture\"\n    LimSwitchC,\n    //%block=\"Bouton poussoir Extérieur\"\n    BPExt,\n    //%block=\"Bouton poussoir Intérieur\"\n    BPInt,\n    //%block=\"Signal Lumineux\"\n    LED,\n    //%block=\"Moteur A1\"\n    A1Motor,\n    //%block=\"Moteur A2\"\n    A2Motor,\n    //%block=\"Récepteur IR\"\n    IRreceptor,\n}\n\nenum LimitSwitch{\n    //%block=\"Ouverture\"\n    Open,\n    //%block=\"Fermeture\"\n    Closed,\n}\n\n//% color=#1E90FF\nenum Servo {\n    S0 = 0,\n    S1,\n    S2,\n    S3,\n    S4,\n    S5\n}\n\n//% color=#FF8C00\nenum IO {\n    C0 = 0,\n    C1,\n    C2,\n    C3,\n    C4,\n    C5\n}\n\n//% color=#FF8C00\nenum GPIOState {\n    //% block=\"LOW\"\n    Low = 0,\n    //% block=\"HIGH\"\n    High = 1\n}\n\n//% color=#FF1493\nenum RGBIndex {\n    //% b