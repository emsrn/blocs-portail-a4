===============\n\n    function setAnalogInput(io: IO) {\n        writeReg(0x2c + io, pins.createBufferFromArray([2]))\n    }\n\n    //% block=\"%action portail\"\n    export function portail(action: Portail){\n        if (action == Portail.CW){\n            digitalWrite(IO.C0, GPIOState.High);\n            digitalWrite(IO.C5, GPIOState.Low)\n        }\n        if (action == Portail.CCW){\n            digitalWrite(IO.C0, GPIOState.Low);\n            digitalWrite(IO.C5, GPIOState.High)\n        }\n        if (action == Portail.Stop){\n            digitalWrite(IO.C0, GPIOState.Low);\n            digitalWrite(IO.C5, GPIOState.Low)\n        }\n    }\n\n    //% block=\"%state signal lumineux\"\n    export function led(state: LED){\n        if (state == LED.ON){\n            pins.digitalWritePin(DigitalPin.P0, 1)\n        }\n        else if (state == LED.OFF){\n            pins.digitalWritePin(DigitalPin.P0, 0)\n        }\n    }\n\n\n    function digitalWrite(io: IO, state: GPIOState) {\n        init()\n        setDigitalOutput(io)\n        writeReg(0x39 + io, pins.createBufferFromArray([state]))\n    }\n\n    function setDigitalOutput(io: IO) {\n        writeReg(0x2c + io, pins.createBufferFromArray([4]))\n    }\n\n    function setDigitalInput(io: IO) {\n        writeReg(0x2c + io, pins.createBufferFromArray([5]))\n    }\n\n}\n\n"},{"type":"added","filename":"enums.ts","value":"//% color=#2E8B57\nenum MotorID {\n    //% block=\"motor 1\"\n    M1 = 0,\n    //% block=\"motor 2\"\n    M2,\n    //% block=\"motor 3\"\n    M3,\n    //% block=\"motor 4\"\n    M4\n}\n\n//% color=#2E8B57\nenum Portail {\n    //% block=\"Ouvrir\"\n    CW = 0,\n    //% block=\"Fermer\"\n    CCW = 1,\n    //% block=\"Arrêter\"\n    Stop,\n}\n\nenum LED {\n    //% block=\"Activer\"\n    ON, \n    //% block=\"Désactiver\"\n    OFF,\n}\n\n//% color=#1E90FF\nenum Servo {\n    S0 = 0,\n    S1,\n    S2,\n    S3,\n    S4,\n    S5\n}\n\n//% color=#FF8C00\nenum IO {\n    C0 = 0,\n    C1,\n    C2,\n    C3,\n 